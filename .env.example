# ============================================================
# Balance Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real credentials.
# ============================================================

# ── MariaDB ──────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=RootPass123!
MARIADB_DATABASE=balance_portal
MARIADB_USER=portaluser
MARIADB_PASSWORD=PortalPass123!

# ── App DB connection (passed into Tomcat container) ─────────
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=balance_portal
DB_USERNAME=portaluser
DB_PASSWORD=PortalPass123!

# ── JWT ──────────────────────────────────────────────────────
# Change this to any random 32+ character string in production
JWT_SECRET=BalancePortalSuperSecretKey12345!

# ── SMTP (mail.com or any provider) ──────────────────────────
SMTP_HOST=smtp.mail.com
SMTP_PORT=587
SMTP_USERNAME=yourname@mail.com
SMTP_PASSWORD=yourpassword
SMTP_FROM=Balance Portal <yourname@mail.com>

# ── App base URL (used in verification email links) ──────────
APP_BASE_URL=http://localhost:8080/balance-portal-db
